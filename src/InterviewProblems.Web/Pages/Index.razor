@page "/"
@implements IAsyncDisposable
@inject ProblemCatalog Catalog
@inject SqlWorkbench Sql
@inject RoslynWorkspaceService Roslyn
@inject CandidateRunner Runner
@inject IJSRuntime JS

<div class="console">
    <aside class="sidebar">
        <h1 class="brand">Interview<span>Console</span></h1>
        <p class="hint">Pick a problem, implement it with IntelliSense, then run the tests. SQL problems run live against the seeded database.</p>
        <a class="nav-link" href="/questions">Verbal / conceptual questions &rarr;</a>

        @foreach (var level in Levels)
        {
            var coding = Catalog.All.Where(p => p.Level == level).ToList();
            var sqlQuestions = Sql.ForLevel(level).ToList();
            if (coding.Count == 0 && sqlQuestions.Count == 0)
            {
                continue;
            }

            <div class="level-group">
                <div class="level-title">@LevelLabel(level)</div>
                @foreach (var problem in coding)
                {
                    <button class="problem @(problem.Id == _current?.Id ? "active" : "")"
                            @onclick="() => SelectProblem(problem)">
                        <span class="problem-name">@problem.DisplayName</span>
                        <span class="problem-tag">@problem.Category</span>
                    </button>
                }
                @foreach (var question in sqlQuestions)
                {
                    <button class="problem @(question.Id == _currentSql?.Id ? "active" : "")"
                            @onclick="() => SelectSql(question)">
                        <span class="problem-name">@question.Title</span>
                        <span class="problem-tag">SQL</span>
                    </button>
                }
            </div>
        }
    </aside>

    <section class="main">
        @if (_currentSql is not null)
        {
            <header class="toolbar">
                <div class="toolbar-title">
                    <strong>@_currentSql.Title</strong>
                    <span class="chip">@LevelLabel(_currentSql.Level)</span>
                    <span class="chip">SQL</span>
                </div>
                <div class="toolbar-actions">
                    <button class="btn ghost" @onclick="() => _showSchema = !_showSchema">
                        @(_showSchema ? "Hide schema" : "Show schema")
                    </button>
                    <button class="btn primary" @onclick="RunSqlAsync" disabled="@_running">
                        @(_running ? "Running…" : "Run query")
                    </button>
                </div>
            </header>

            <div class="sql-prompt">
                <p class="sql-prompt-text">@_currentSql.Prompt</p>
                @if (_showSchema)
                {
                    <div class="schema">
                        @foreach (var table in Sql.Schema)
                        {
                            <div class="schema-table">
                                <div class="schema-table-name">@table.Name</div>
                                <ul class="schema-cols">
                                    @foreach (var column in table.Columns)
                                    {
                                        <li>
                                            <span class="schema-col-name">@column.Name</span>
                                            <span class="schema-col-type">@column.Type</span>
                                        </li>
                                    }
                                </ul>
                            </div>
                        }
                    </div>
                }
            </div>
        }
        else if (_current is not null)
        {
            <header class="toolbar">
                <div class="toolbar-title">
                    <strong>@_current.DisplayName</strong>
                    <span class="chip">@LevelLabel(_current.Level)</span>
                    <span class="chip">@_current.Category</span>
                </div>
                <div class="toolbar-actions">
                    <button class="btn ghost" @onclick="ResetAsync" disabled="@_running">Reset to stub</button>
                    <button class="btn primary" @onclick="RunAsync" disabled="@_running">
                        @(_running ? "Running…" : "Run tests")
                    </button>
                </div>
            </header>
        }

        @if (_currentSql is not null)
        {
            <div class="editor-host sql-editor-host">
                <textarea id="sql-editor"
                          class="sql-editor"
                          @bind="_sqlCode"
                          @bind:event="oninput"
                          spellcheck="false"
                          autocapitalize="off"
                          autocomplete="off"
                          autocorrect="off"
                          aria-label="SQL query editor"></textarea>
            </div>
        }
        else if (_current is not null)
        {
            <div class="editor-host">
                <div id="editor" class="editor"></div>
            </div>
        }
        else
        {
            <div class="placeholder">Select a problem to begin.</div>
        }

        @if (_currentSql is not null)
        {
            <div class="results">
                @if (_sqlResult is null)
                {
                    <div class="results-empty">Run your query to see the result grid.</div>
                }
                else if (!_sqlResult.Executed)
                {
                    <div class="results-header fail">SQL error</div>
                    <pre class="sql-error">@_sqlResult.Error</pre>
                }
                else
                {
                    <div class="results-header @(_sqlResult.Correct ? "pass" : "fail")">
                        @(_sqlResult.Correct
                            ? "Correct — result matches the expected output."
                            : "Not quite — result does not match the expected output.")
                    </div>
                    <div class="result-meta">
                        @_sqlResult.Rows.Count row(s) returned · @_sqlResult.ExpectedRowCount expected
                    </div>
                    @if (_sqlResult.Columns.Count == 0)
                    {
                        <div class="results-empty">Query returned no columns.</div>
                    }
                    else
                    {
                        <div class="grid-wrap">
                            <table class="grid">
                                <thead>
                                    <tr>
                                        @foreach (var column in _sqlResult.Columns)
                                        {
                                            <th>@column</th>
                                        }
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var row in _sqlResult.Rows)
                                    {
                                        <tr>
                                            @foreach (var cell in row)
                                            {
                                                <td>@cell</td>
                                            }
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                }
            </div>
        }
        else if (_current is not null)
        {
            <div class="results">
                @if (_result is null)
                {
                    <div class="results-empty">Run the tests to see how your implementation does.</div>
                }
                else if (!_result.Compiled)
                {
                    <div class="results-header fail">Compilation failed</div>
                    <ul class="issue-list">
                        @foreach (var error in _result.Errors)
                        {
                            <li class="issue">
                                <span class="loc">@(error.InCandidateCode ? $"Line {error.Line}" : "test harness")</span>
                                <span class="msg">@error.Message</span>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <div class="results-header @(_result.AllPassed ? "pass" : "fail")">
                        @_result.Passed / @_result.Total tests passing
                    </div>
                    <ul class="test-list">
                        @foreach (var test in _result.Tests)
                        {
                            <li class="test @(test.Passed ? "ok" : "bad")">
                                <span class="badge">@(test.Passed ? "PASS" : "FAIL")</span>
                                <span class="test-name">@test.Name</span>
                                @if (!test.Passed && test.FailureMessage is not null)
                                {
                                    <div class="test-msg">@test.FailureMessage</div>
                                }
                            </li>
                        }
                    </ul>
                }
            </div>
        }
    </section>
</div>

@code {
    private static readonly string[] Levels = { "Developer1", "Developer2", "Senior" };

    private DotNetObjectReference<Index>? _ref;
    private ProblemSet? _current;
    private SqlQuestion? _currentSql;
    private RunResult? _result;
    private SqlRunResult? _sqlResult;
    private string _sqlCode = string.Empty;
    private bool _running;
    private bool _showSchema;

    // The Monaco editor language currently mounted ("csharp" | "sql" | null) and
    // the source to load into it on the next render sync.
    private string? _editorMode;
    private string? _pendingCode;

    protected override void OnInitialized()
    {
        _current = Catalog.All.FirstOrDefault();
        _pendingCode = _current?.StubCode;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _ref = DotNetObjectReference.Create(this);
        }

        await SyncEditorAsync();
    }

    /// <summary>
    /// Reconciles the mounted Monaco editor with the current C# selection. SQL
    /// uses a native textarea so it remains editable with touch input.
    /// </summary>
    private async Task SyncEditorAsync()
    {
        var target = _current is not null ? "csharp" : null;

        if (target is null)
        {
            if (_editorMode is not null)
            {
                try { await JS.InvokeVoidAsync("monacoInterop.dispose"); } catch { /* circuit gone */ }
                _editorMode = null;
            }

            return;
        }

        if (target == _editorMode)
        {
            if (_pendingCode is not null)
            {
                await JS.InvokeVoidAsync("monacoInterop.setValue", _pendingCode);
                _pendingCode = null;
            }

            return;
        }

        if (_editorMode is not null)
        {
            try { await JS.InvokeVoidAsync("monacoInterop.dispose"); } catch { /* circuit gone */ }
        }

        var initial = _pendingCode ?? string.Empty;
        await JS.InvokeVoidAsync("monacoInterop.init", "editor", _ref, initial, "csharp");

        _editorMode = target;
        _pendingCode = null;
    }

    private void SelectProblem(ProblemSet problem)
    {
        if (_running || problem.Id == _current?.Id)
        {
            return;
        }

        _current = problem;
        _currentSql = null;
        _result = null;
        _sqlResult = null;
        _pendingCode = problem.StubCode;
    }

    private void SelectSql(SqlQuestion question)
    {
        if (_running || question.Id == _currentSql?.Id)
        {
            return;
        }

        _currentSql = question;
        _current = null;
        _result = null;
        _sqlResult = null;
        _showSchema = false;
        _sqlCode = question.StarterSql;
    }

    private async Task ResetAsync()
    {
        if (_current is null)
        {
            return;
        }

        _result = null;
        await JS.InvokeVoidAsync("monacoInterop.setValue", _current.StubCode);
    }

    private async Task RunAsync()
    {
        if (_current is null || _running)
        {
            return;
        }

        _running = true;
        _result = null;
        StateHasChanged();

        try
        {
            var code = await JS.InvokeAsync<string>("monacoInterop.getValue");
            _result = await Runner.RunAsync(_current, code);
        }
        catch (Exception ex)
        {
            _result = new RunResult
            {
                Compiled = false,
                Errors = new[] { new CompileError(ex.Message, 0, 0, false) },
            };
        }
        finally
        {
            _running = false;
            StateHasChanged();
        }
    }

    private async Task RunSqlAsync()
    {
        if (_currentSql is null || _running)
        {
            return;
        }

        _running = true;
        _sqlResult = null;
        StateHasChanged();

        try
        {
            _sqlResult = Sql.Run(_currentSql.Id, _sqlCode);
        }
        catch (Exception ex)
        {
            _sqlResult = new SqlRunResult { Executed = false, Error = ex.Message };
        }
        finally
        {
            _running = false;
            StateHasChanged();
        }
    }

    [JSInvokable]
    public async Task<IReadOnlyList<CompletionEntry>> ProvideCompletions(string code, int offset)
        => await Roslyn.GetCompletionsAsync(code, offset);

    [JSInvokable]
    public IReadOnlyList<EditorMarker> ProvideDiagnostics(string code)
        => Roslyn.GetDiagnostics(code);

    private static string LevelLabel(string level) => level switch
    {
        "Developer1" => "Developer 1",
        "Developer2" => "Developer 2",
        _ => level,
    };

    public async ValueTask DisposeAsync()
    {
        if (_editorMode is not null)
        {
            try { await JS.InvokeVoidAsync("monacoInterop.dispose"); } catch { /* circuit gone */ }
        }

        _ref?.Dispose();
    }
}
